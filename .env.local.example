# ------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser (safe values
# only). Everything else is server-only and must stay secret.
# ------------------------------------------------------------------

# Public site URL (used to build return/webhook URLs). Optional in dev.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Order defaults (amount is in the smallest currency unit, e.g. cents)
NEXT_PUBLIC_DEFAULT_AMOUNT=25000
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# Toggle gateways on/off in the checkout UI ("false" to hide)
NEXT_PUBLIC_ENABLE_PAYCOM=true
NEXT_PUBLIC_ENABLE_BRIDGERPAY=true

# ----------------------------- Statsig ----------------------------
# A/B testing + feature flags. Project -> Settings -> Keys & Environments.
# Client SDK key (safe to expose) — used for bootstrap + browser events.
NEXT_PUBLIC_STATSIG_CLIENT_KEY=client-xxx
# Server secret key (must stay secret) — generates bootstrap values and logs
# server-side conversion events. A/B features no-op if either key is unset.
STATSIG_SERVER_SECRET_KEY=secret-xxx

# ----------------------------- Pay.com ----------------------------
# Dashboard -> Developers -> API keys
PAYCOM_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_PAYCOM_PUBLISHABLE_KEY=pk_live_or_test_xxx
# Webhook signing secret (Dashboard -> Developers -> Webhooks)
PAYCOM_WEBHOOK_SECRET=
# Override only if your account differs:
# PAYCOM_API_BASE=https://api.pay.com
# PAYCOM_CREATE_SESSION_PATH=/v1/sessions/payment
# NEXT_PUBLIC_PAYCOM_SDK_URL=https://cdn.pay.com/sdk/v1/pay.js

# --------------------------- BridgerPay ---------------------------
# Dashboard -> Developers / API credentials. Put the real values in .env.local
# (gitignored) and the production env vars in Vercel — never commit them here.
BRIDGERPAY_API_KEY=
BRIDGERPAY_CASHIER_KEY=
BRIDGERPAY_USERNAME=
BRIDGERPAY_PASSWORD=
# Postback signing secret (NOT the webhook URL). Register the webhook URL
# (https://YOUR_DOMAIN/api/payments/bridgerpay/webhook) in the BridgerPay
# dashboard. Leave this empty until they provide a signing secret.
BRIDGERPAY_WEBHOOK_SECRET=
# Override only if your account differs:
# BRIDGERPAY_API_BASE=https://api.bridgerpay.com
# BRIDGERPAY_AUTH_PATH=/v2/auth/login
# NEXT_PUBLIC_BRIDGERPAY_CHECKOUT_URL=https://checkout.bridgerpay.com/v2/launcher
